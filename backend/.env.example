# ====================================================
# 한국투자증권 Open API 설정
# https://apiportal.koreainvestment.com 에서 발급
# ====================================================

# 실전투자 or 모의투자 선택 (real / paper)
KIS_MODE=paper

# 실전투자 App Key / Secret
KIS_APP_KEY=your_real_app_key_here
KIS_APP_SECRET=your_real_app_secret_here

# 모의투자(paper) App Key / Secret  ← 무료 테스트 권장
KIS_PAPER_APP_KEY=your_paper_app_key_here
KIS_PAPER_APP_SECRET=your_paper_app_secret_here

# 실전투자 계좌번호 (8자리, 조회용)
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT_CODE=01

# 네이버 뉴스 검색 API (선택사항)
# https://developers.naver.com/apps 에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# CORS 허용 출처 (쉼표 구분, * 는 전체 허용)
ALLOWED_ORIGINS=*

# 서버 포트 (Railway 자동 지정)
PORT=8000
